# PipeWire filter-chain room simulator for E2E testing (US-050).
#
# 8 convolvers (one per convolver output channel) mixed to 1 mono output
# simulating a microphone in the room.  IR WAV files are generated by
# export_room_irs.py (EH-1) and substituted into this template by
# start-room-sim.sh.
#
# Audio graph:
#   convolver playback -> [8ch capture] -> 8x convolver -> mixer -> [1ch playback]
#   -> signal-gen capture (simulated UMIK-1)

context.modules = [
{
  name = libpipewire-module-filter-chain
  args = {
    node.description = "E2E Room Simulator"
    media.name        = "E2E Room Simulator"
    filter.graph = {
      nodes = [
        { type = builtin  name = conv0  label = convolver  config = { filename = "@IR_DIR@/room_ir_ch0.wav" } }
        { type = builtin  name = conv1  label = convolver  config = { filename = "@IR_DIR@/room_ir_ch1.wav" } }
        { type = builtin  name = conv2  label = convolver  config = { filename = "@IR_DIR@/room_ir_ch2.wav" } }
        { type = builtin  name = conv3  label = convolver  config = { filename = "@IR_DIR@/room_ir_ch3.wav" } }
        { type = builtin  name = conv4  label = convolver  config = { filename = "@IR_DIR@/room_ir_ch4.wav" } }
        { type = builtin  name = conv5  label = convolver  config = { filename = "@IR_DIR@/room_ir_ch5.wav" } }
        { type = builtin  name = conv6  label = convolver  config = { filename = "@IR_DIR@/room_ir_ch6.wav" } }
        { type = builtin  name = conv7  label = convolver  config = { filename = "@IR_DIR@/room_ir_ch7.wav" } }
        {
          type    = builtin
          name    = mix
          label   = mixer
          control = {
            "Gain 1" = 1.0  "Gain 2" = 1.0  "Gain 3" = 1.0  "Gain 4" = 1.0
            "Gain 5" = 1.0  "Gain 6" = 1.0  "Gain 7" = 1.0  "Gain 8" = 1.0
          }
        }
      ]
      links = [
        { output = "conv0:Out"  input = "mix:In 1" }
        { output = "conv1:Out"  input = "mix:In 2" }
        { output = "conv2:Out"  input = "mix:In 3" }
        { output = "conv3:Out"  input = "mix:In 4" }
        { output = "conv4:Out"  input = "mix:In 5" }
        { output = "conv5:Out"  input = "mix:In 6" }
        { output = "conv6:Out"  input = "mix:In 7" }
        { output = "conv7:Out"  input = "mix:In 8" }
      ]
      inputs  = [ "conv0:In" "conv1:In" "conv2:In" "conv3:In"
                   "conv4:In" "conv5:In" "conv6:In" "conv7:In" ]
      outputs = [ "mix:Out" ]
    }
    capture.props = {
      node.name   = "pi4audio-e2e-room-sim-capture"
      media.class = Audio/Sink
      audio.channels = 8
      audio.position = [ AUX0 AUX1 AUX2 AUX3 AUX4 AUX5 AUX6 AUX7 ]
    }
    playback.props = {
      node.name    = "pi4audio-e2e-room-sim-playback"
      node.passive = true
      audio.channels = 1
      audio.position = [ MONO ]
    }
  }
}
]
