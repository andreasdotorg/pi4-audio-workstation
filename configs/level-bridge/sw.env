# level-bridge-sw: taps active app output ports (F-124/F-125)
# GM creates mode-specific links: Mixxx (4ch), Reaper (8ch), signal-gen (1ch).
# 8 channels to accommodate Reaper's full output; unused channels show silence.
# In --managed mode, TARGET is not used for linking (GM manages links).
LINK_MODE=--managed
NODE_NAME=pi4audio-level-bridge-sw
MODE=capture
TARGET=unused-managed-mode
PORT=9100
CHANNELS=8
RATE=48000
