# pcm-bridge capture-usb instance — reads from USBStreamer ALSA input.
# Captures ADA8200 ADAT channels via the USBStreamer source node.
# D-040: TARGET updated for consistency (--node-name in EXTRA_ARGS is the
# actual selector; TARGET is a fallback that was never used).
# Deployed to /etc/pcm-bridge/capture-usb.env on the Pi.

MODE=capture
TARGET=alsa_input.usb-MiniDSP_USBStreamer-00.pro-input-0
PORT=9091
CHANNELS=8
RATE=48000
QUANTUM=256
EXTRA_ARGS=--node-name alsa_input.usb-MiniDSP_USBStreamer-00.pro-input-0
