# pcm-bridge monitor instance — taps convolver input (pre-FIR, post-routing).
# D-040: retargeted from loopback-8ch-sink to PW filter-chain convolver.
# Passive monitoring: does not participate in the RT audio graph, cannot cause xruns.
# Deployed to /etc/pcm-bridge/monitor.env on the Pi.

MODE=monitor
TARGET=pi4audio-convolver
PORT=9090
CHANNELS=4
RATE=48000
QUANTUM=256
LEVELS_LISTEN=tcp:127.0.0.1:9100
