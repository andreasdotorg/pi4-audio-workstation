+static void convolver_control_changed(void * Instance)
+{
+	struct convolver_impl *impl = Instance;
+	struct plugin *pl = impl->plugin;
+	float *samples;
+	int n_samples = 0, def_latency;
+	unsigned long rate;
+	struct convolver *conv;
+
+	if (impl->old) {
+		convolver_free(impl->old);
+		impl->old = NULL;
+	}
+
+	if (impl->port[3] == NULL || impl->port[3][0] == 0.0f)
+		return;
+
+	impl->port[3][0] = 0.0f;
+
+	spa_log_info(impl->log, "convolver: reloading coefficients");
+
+	rate = impl->rate;
+	samples = read_closest(pl, impl->filenames, impl->gain, impl->delay,
+			impl->offset, impl->length, impl->channel,
+			&rate, &n_samples, &def_latency);
+	if (samples != NULL && rate != impl->rate)
+		samples = resample_buffer(pl, samples, &n_samples,
+				rate, impl->rate, impl->resample_quality);
+
+	if (samples == NULL) {
+		spa_log_error(impl->log, "convolver: reload failed, keeping old coefficients");
+		return;
+	}
+
+	conv = convolver_new(impl->dsp, impl->blocksize, impl->tailsize, samples, n_samples);
+	free(samples);
+
+	if (conv == NULL) {
+		spa_log_error(impl->log, "convolver: creating new convolver failed, keeping old coefficients");
+		return;
+	}
+
+	impl->next = conv;
+
+	if (impl->latency_conf < 0.0f)
+		impl->latency = def_latency;
+	else
+		impl->latency = impl->latency_conf * impl->rate;
+
+	if (pl->data_loop) {
+		spa_loop_locked(pl->data_loop, do_convolver_swap, 1, NULL, 0, impl);
+	} else {
+		impl->old = impl->conv;
+		impl->conv = impl->next;
+		impl->next = NULL;
+	}
+
+	spa_log_info(impl->log, "convolver: reloaded with n_samples:%d", n_samples);
+}
